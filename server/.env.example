# Porta do servidor
PORT=4000

# Segredo usado para criptografar a chave da API Tecimob no banco (AES-256-GCM).
# Gere um valor forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=troque-por-um-segredo-forte

# URL base da API Tecimob (ajuste se a sua conta usar outro endpoint)
TECIMOB_BASE_URL=https://api.tecimob.com.br

# Diretório do banco SQLite (opcional; padrão: server/data)
# DATA_DIR=/data

# ── Login com Google (recomendado em produção) ──────────────────────
# Sem GOOGLE_CLIENT_ID o CRM fica ABERTO (sem login) e exibe um aviso.
# Crie um OAuth Client ID (tipo Web) em https://console.cloud.google.com
# e autorize as origens do seu CRM (ver README → "Login com Google").
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# E-mails com acesso (separados por vírgula). Aceita domínios com @:
# ALLOWED_EMAILS=hsfrep@gmail.com,contato@aelimoveis.com.br

# Login alternativo por e-mail + senha compartilhada (mesma allowlist).
# Pode ser usado sozinho (sem Google) ou junto com o GOOGLE_CLIENT_ID.
# LOGIN_PASSWORD=defina-uma-senha-forte
